# Template environment variables — copy to .env and isi nilai aslinya.
# File .env asli DI-IGNORE oleh git (lihat .gitignore). JANGAN commit secret.

# Database — WAJIB PostgreSQL (Supabase). Schema Prisma pakai provider "postgresql".
# Supabase Pooled (recommended untuk Vercel/Next.js serverless):
#   postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Untuk Prisma migrate, gunakan connection string direct (tanpa pgbouncer) di port 5432

# Google OAuth
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Session secret — JWT signing key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Opsional: service role key (server-side only, JANGAN prefix NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=""

NODE_ENV=development

# Opsional: Upstash Redis untuk rate limiting serverless
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""