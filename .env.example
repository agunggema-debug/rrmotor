# Template environment variables — copy to .env dan isi nilai aslinya.
# File .env asli DI-IGNORE oleh git (lihat .gitignore). JANGAN commit secret.

# Database — WAJIB PostgreSQL (Supabase).
# Prisma sudah dihapus, sekarang pakai Supabase client langsung.

# Supabase (WAJIB)
# Dapatkan dari: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon_key>"
# Service role key (server-side only, JANGAN prefix NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"

# Google OAuth (opsional, untuk login Google)
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Session secret — JWT signing key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

NODE_ENV=development

# Opsional: Upstash Redis untuk rate limiting serverless
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""